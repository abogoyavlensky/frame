(ns frame.new-test
  (:require [clojure.test :refer [deftest is]]
            [frame.new :as new]))

;; ---------------------------------------------------------------------------
;; var-summary-lines: declared vars + final answers -> printable lines
;; ---------------------------------------------------------------------------

(def ^:private demo-vars
  [{:key :db
    :prompt "Database"
    :type :enum
    :options ["sqlite" "postgres"]
    :default "sqlite"}
   {:key :auth
    :prompt "Include authentication?"
    :type :boolean
    :default true}
   {:key :author
    :prompt "Author name"
    :type :string
    :default ""}])

(deftest summary-mixed-types-in-config-order
  (is (= ["Variables:"
          "  db: postgres"
          "  auth: false"
          "  author: Jane"]
         (new/var-summary-lines demo-vars
                                {"db" "postgres"
                                 "auth" false
                                 "author" "Jane"}))))

(deftest summary-empty-vars-yields-no-lines
  (is (= [] (new/var-summary-lines [] {"db" "postgres"}))))

(deftest summary-ignores-built-ins-and-computed
  (is (= ["Variables:"
          "  db: sqlite"
          "  auth: true"
          "  author: Jane"]
         (new/var-summary-lines demo-vars
                                {"db" "sqlite"
                                 "auth" true
                                 "author" "Jane"
                                 "project-name" "demo-app"
                                 "now-date" "2026-07-10"
                                 "now-year" "2026"
                                 "top-ns" "demo_app"}))))

(deftest summary-empty-string-value
  (is (= ["Variables:"
          "  author: "]
         (new/var-summary-lines [(nth demo-vars 2)] {"author" ""}))))

;; ---------------------------------------------------------------------------
;; target-error: pure gate for whether a target dir may be generated into
;; ---------------------------------------------------------------------------

(deftest target-error-absent-is-ok
  (is (nil? (new/target-error "t" nil true false)))
  (is (nil? (new/target-error "t" nil true true))))

(deftest target-error-file-always-fails
  (is (some? (re-find #"not a directory" (new/target-error "t" {:dir? false} true false))))
  ;; a file target is an error even under --force
  (is (some? (re-find #"not a directory" (new/target-error "t" {:dir? false} true true)))))

(deftest target-error-empty-dir-is-ok
  (is (nil? (new/target-error "t" {:dir? true} true false))))

(deftest target-error-nonempty-dir-needs-force
  (let [msg (new/target-error "t" {:dir? true} false false)]
    (is (some? msg))
    (is (some? (re-find #"--force" msg))))
  (is (nil? (new/target-error "t" {:dir? true} false true))))

;; ---------------------------------------------------------------------------
;; contains-unsafe-entry?: --force must refuse symlinks, hard links, and
;; special files (FIFO/socket/device) in the target
;; ---------------------------------------------------------------------------

(defn- tmp-dir []
  (str (os/temp-dir) "/frame-new-test-" (rand-int 100000000)))

(deftest contains-unsafe-entry-detects-links-specials-and-fails-closed
  (let [plain (tmp-dir)
        symd (tmp-dir)
        hard (tmp-dir)
        fifod (tmp-dir)
        outside (tmp-dir)]
    (mkdir outside)
    (spit (str outside "/victim") "secret")
    ;; plain dir with a nested regular file is safe
    (mkdir plain)
    (mkdir (str plain "/sub"))
    (spit (str plain "/sub/file.txt") "x")
    ;; symlink
    (mkdir symd)
    (os/sh "ln" "-s" outside (str symd "/link"))
    ;; hard link to an outside file
    (mkdir hard)
    (os/sh "ln" (str outside "/victim") (str hard "/README.md"))
    ;; FIFO / special file
    (mkdir fifod)
    (os/sh "mkfifo" (str fifod "/pipe"))
    (is (false? (new/contains-unsafe-entry? plain)))
    (is (true? (new/contains-unsafe-entry? symd)))
    (is (true? (new/contains-unsafe-entry? hard)))
    (is (true? (new/contains-unsafe-entry? fifod)))
    ;; fail closed: an unscannable path counts as unsafe
    (is (true? (new/contains-unsafe-entry? "/nonexistent-frame-xyz-123")))
    (os/sh "rm" "-rf" plain symd hard fifod outside)))
