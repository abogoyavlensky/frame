(ns frame.template.parser-test
  (:require [clojure.test :refer [deftest is]]
            [frame.template.lexer :as lex]
            [frame.template.parser :as p]))

(defn- parse-str [s]
  (p/parse (lex/tokenize s)))

(defn- syntax-error [f]
  (try (f) :no-throw (catch e (ex-data e))))

;; ---------------------------------------------------------------------------
;; Condition grammar
;; ---------------------------------------------------------------------------

(deftest cond-bare-var
  (is (= {:op :term
          :kind :ident
          :value "x"}
         (p/parse-cond "x"))))

(deftest cond-not
  (is (= {:op :not
          :expr {:op :term
                 :kind :ident
                 :value "x"}}
         (p/parse-cond "not x"))))

(deftest cond-eq-bare
  (is (= {:op :cmp
          :cmp-op :eq
          :left {:op :term
                 :kind :ident
                 :value "db"}
          :right {:op :term
                  :kind :ident
                  :value "postgres"}}
         (p/parse-cond "db == postgres"))))

(deftest cond-eq-quoted
  (is (= {:op :cmp
          :cmp-op :eq
          :left {:op :term
                 :kind :ident
                 :value "db"}
          :right {:op :term
                  :kind :str
                  :value "postgres"}}
         (p/parse-cond "db == \"postgres\""))))

(deftest cond-neq
  (is (= {:op :cmp
          :cmp-op :neq
          :left {:op :term
                 :kind :ident
                 :value "a"}
          :right {:op :term
                  :kind :ident
                  :value "b"}}
         (p/parse-cond "a != b"))))

(deftest cond-and
  (is (= {:op :and
          :left {:op :term
                 :kind :ident
                 :value "a"}
          :right {:op :term
                  :kind :ident
                  :value "b"}}
         (p/parse-cond "a and b"))))

(deftest cond-or-and-precedence
  ;; "a or b and c" parses as "a or (b and c)".
  (is (= {:op :or
          :left {:op :term
                 :kind :ident
                 :value "a"}
          :right {:op :and
                  :left {:op :term
                         :kind :ident
                         :value "b"}
                  :right {:op :term
                          :kind :ident
                          :value "c"}}}
         (p/parse-cond "a or b and c"))))

(deftest cond-quoted-with-spaces
  (is (= {:op :cmp
          :cmp-op :eq
          :left {:op :term
                 :kind :ident
                 :value "name"}
          :right {:op :term
                  :kind :str
                  :value "hello world"}}
         (p/parse-cond "name == \"hello world\""))))

(deftest cond-garbage-throws
  (is (= :syntax (:reason (syntax-error #(p/parse-cond "==")))))
  (is (= :syntax (:reason (syntax-error #(p/parse-cond "a b")))))
  (is (= :syntax (:reason (syntax-error #(p/parse-cond "a =="))))))

(deftest cond-lone-operator-throws-not-hangs
  ;; A lone `=` or `!` must raise a syntax error instead of looping forever.
  (is (= :syntax (:reason (syntax-error #(p/parse-cond "a = b")))))
  (is (= :syntax (:reason (syntax-error #(p/parse-cond "a ! b")))))
  (is (= :syntax (:reason (syntax-error #(parse-str "{% if a = b %}x{% endif %}"))))))

;; ---------------------------------------------------------------------------
;; Block parsing: nodes
;; ---------------------------------------------------------------------------

(deftest parse-text-node
  (is (= [{:node :text
           :value "hello"}]
         (parse-str "hello"))))

(deftest parse-output-node
  (is (= [{:node :output
           :var "x"
           :filters []
           :line 1}]
         (parse-str "{{ x }}"))))

(deftest parse-output-with-filters
  (is (= [{:node :output
           :var "project-name"
           :filters ["snake_case" "upper"]
           :line 1}]
         (parse-str "{{ project-name | snake_case | upper }}"))))

(deftest parse-simple-if
  (is (= [{:node :if
           :branches [{:cond {:op :term
                              :kind :ident
                              :value "x"}
                       :body [{:node :text
                               :value "A"}]}]
           :else nil}]
         (parse-str "{% if x %}A{% endif %}"))))

(deftest parse-if-elsif-else
  (is (= [{:node :if
           :branches [{:cond {:op :term
                              :kind :ident
                              :value "a"}
                       :body [{:node :text
                               :value "A"}]}
                      {:cond {:op :term
                              :kind :ident
                              :value "b"}
                       :body [{:node :text
                               :value "B"}]}]
           :else [{:node :text
                   :value "C"}]}]
         (parse-str "{% if a %}A{% elsif b %}B{% else %}C{% endif %}"))))

(deftest parse-nested-if
  (is (= [{:node :if
           :branches [{:cond {:op :term
                              :kind :ident
                              :value "a"}
                       :body [{:node :if
                               :branches [{:cond {:op :term
                                                  :kind :ident
                                                  :value "b"}
                                           :body [{:node :text
                                                   :value "X"}]}]
                               :else nil}]}]
           :else nil}]
         (parse-str "{% if a %}{% if b %}X{% endif %}{% endif %}"))))

(deftest parse-case-with-else
  (is (= [{:node :case
           :var "db"
           :whens [{:value "sqlite"
                    :body [{:node :text
                            :value "S"}]}
                   {:value "postgres"
                    :body [{:node :text
                            :value "P"}]}]
           :else [{:node :text
                   :value "D"}]}]
         (parse-str (str "{% case db %}"
                         "{% when \"sqlite\" %}S"
                         "{% when postgres %}P"
                         "{% else %}D"
                         "{% endcase %}")))))

(deftest quoted-literal-internal-whitespace-preserved
  ;; Through a full tag: tag-parts must not collapse the literal's inner spaces.
  (is (= [{:node :if
           :branches [{:cond {:op :cmp
                              :cmp-op :eq
                              :left {:op :term
                                     :kind :ident
                                     :value "name"}
                              :right {:op :term
                                      :kind :str
                                      :value "hello   world"}}
                       :body [{:node :text
                               :value "x"}]}]
           :else nil}]
         (parse-str "{% if name == \"hello   world\" %}x{% endif %}"))))

(deftest when-quoted-internal-whitespace-preserved
  (is (= [{:node :case
           :var "x"
           :whens [{:value "a  b"
                    :body [{:node :text
                            :value "S"}]}]
           :else nil}]
         (parse-str "{% case x %}{% when \"a  b\" %}S{% endcase %}"))))

(deftest parse-case-discards-text-before-first-when
  (is (= [{:node :case
           :var "db"
           :whens [{:value "sqlite"
                    :body [{:node :text
                            :value "S"}]}]
           :else nil}]
         (parse-str "{% case db %}   ignored   {% when sqlite %}S{% endcase %}"))))

;; ---------------------------------------------------------------------------
;; Block parsing: errors with :line
;; ---------------------------------------------------------------------------

(deftest endif-without-if-throws
  (let [data (syntax-error #(parse-str "a\n{% endif %}"))]
    (is (= :syntax (:reason data)))
    (is (= 2 (:line data)))))

(deftest unclosed-if-at-eof-throws
  (let [data (syntax-error #(parse-str "{% if x %}body"))]
    (is (= :syntax (:reason data)))
    (is (= 1 (:line data)))))

(deftest elsif-after-else-throws
  (let [data (syntax-error #(parse-str "{% if a %}A{% else %}B{% elsif c %}C{% endif %}"))]
    (is (= :syntax (:reason data)))))

(deftest when-outside-case-throws
  (let [data (syntax-error #(parse-str "{% when sqlite %}S"))]
    (is (= :syntax (:reason data)))))

(deftest unknown-tag-word-throws
  (let [data (syntax-error #(parse-str "{% frobnicate x %}"))]
    (is (= :syntax (:reason data)))))
