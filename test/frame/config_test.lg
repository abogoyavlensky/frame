(ns frame.config-test
  (:require [clojure.test :refer [deftest is]]
            [frame.config :as config]
            [frame.version :as version]
            [string :as str]))

;; Write edn-str as frame.edn in a throwaway dir and read it back.
(defn- read-edn [edn-str]
  (let [dir (str (os/temp-dir) "/frame-config-test-" (rand-int 100000000))]
    (mkdir dir)
    (spit (str dir "/frame.edn") edn-str)
    (let [r (try (config/read-config dir)
                 (catch e {:error (ex-data e)
                           :msg (ex-message e)}))]
      (os/sh "rm" "-rf" dir)
      r)))

(defn- read-cfg [cfg]
  (read-edn (pr-str cfg)))

;; ---------------------------------------------------------------------------
;; Valid configs + defaults
;; ---------------------------------------------------------------------------

(deftest applies-defaults-for-optional-keys
  (let [r (read-cfg {:vars []})]
    (is (= "template" (:root r)))
    (is (= {} (:computed r)))
    (is (= [] (:raw r)))
    (is (= [] (:vars r)))))

(deftest reads-full-config
  (let [cfg {:description "Lightweight Clojure stack"
             :root "tpl"
             :vars [{:key :db
                     :prompt "Database"
                     :type :enum
                     :options ["sqlite" "postgres"]
                     :default "sqlite"}
                    {:key :auth
                     :prompt "Include auth?"
                     :type :boolean
                     :default true}
                    {:key :author
                     :prompt "Author"
                     :type :string
                     :default ""}]
             :computed {:top-ns "{{project-name | snake_case}}"}
             :raw ["**/*.png"]}
        r (read-cfg cfg)]
    (is (= "Lightweight Clojure stack" (:description r)))
    (is (= "tpl" (:root r)))
    (is (= 3 (count (:vars r))))
    (is (= :db (:key (first (:vars r)))))
    (is (= {:top-ns "{{project-name | snake_case}}"} (:computed r)))
    (is (= ["**/*.png"] (:raw r)))))

;; ---------------------------------------------------------------------------
;; Semver helpers
;; ---------------------------------------------------------------------------

(deftest parse-semver-accepts-exact-x-y-z
  (is (= [0 3 0] (config/parse-semver "0.3.0")))
  (is (= [1 22 333] (config/parse-semver "1.22.333"))))

(deftest parse-semver-rejects-everything-else
  (is (nil? (config/parse-semver "1.2")))
  (is (nil? (config/parse-semver "1.2.3.4")))
  (is (nil? (config/parse-semver "abc")))
  (is (nil? (config/parse-semver "1.2.x")))
  (is (nil? (config/parse-semver "")))
  (is (nil? (config/parse-semver 1.2)))
  (is (nil? (config/parse-semver nil)))
  ;; components beyond parse-long's range must reject, not parse as nil
  (is (nil? (config/parse-semver "999999999999999999999.0.0"))))

;; Run check-min-version! and return nil on success or ex-data on throw.
(defn- check-min [min-version current]
  (try (config/check-min-version! min-version current)
       nil
       (catch e (assoc (ex-data e) :msg (ex-message e)))))

(deftest check-min-version-absent-is-noop
  (is (nil? (check-min nil "0.1.0"))))

(deftest check-min-version-satisfied-passes
  (is (nil? (check-min "0.0.1" "0.1.0")))
  (is (nil? (check-min "0.1.0" "0.1.0"))))

(deftest check-min-version-too-old-errors
  (let [r (check-min "0.2.0" "0.1.0")]
    (is (= :config (:reason r)))
    (is (str/includes? (:msg r) "0.2.0"))
    (is (str/includes? (:msg r) "0.1.0"))))

(deftest check-min-version-compares-numerically
  ;; 0.10.0 is newer than 0.9.0; lexicographic comparison would get this wrong.
  (is (nil? (check-min "0.9.0" "0.10.0"))))

(deftest check-min-version-malformed-errors
  (is (= :config (:reason (check-min "1.2" "0.1.0"))))
  (is (= :config (:reason (check-min "abc" "0.1.0"))))
  (is (= :config (:reason (check-min 1.2 "0.1.0")))))

;; ---------------------------------------------------------------------------
;; :min-frame-version and unknown-key warnings through read-config
;; ---------------------------------------------------------------------------

(deftest no-min-frame-version-reads-fine
  (let [r (read-cfg {:vars []})]
    (is (= [] (:warnings r)))))

(deftest satisfied-min-frame-version-reads-fine
  (let [r (read-cfg {:min-frame-version "0.0.1"
                     :vars []})]
    (is (= [] (:warnings r)))))

(deftest unsatisfied-min-frame-version-errors
  (let [r (read-cfg {:min-frame-version "999.0.0"
                     :vars []})]
    (is (= :config (:reason (:error r))))
    (is (str/includes? (:msg r) "999.0.0"))
    (is (str/includes? (:msg r) version/current))))

(deftest malformed-min-frame-version-errors
  (is (= :config (:reason (:error (read-cfg {:min-frame-version "1.2"
                                             :vars []})))))
  (is (= :config (:reason (:error (read-cfg {:min-frame-version 1.2
                                             :vars []}))))))

(deftest min-frame-version-checked-before-var-validation
  ;; A too-new template with an unknown var type must report the version, not
  ;; the var type — that is the whole point of checking the version first.
  (let [r (read-cfg {:min-frame-version "999.0.0"
                     :vars [{:key :db
                             :prompt "P"
                             :type :future-type}]})]
    (is (= :config (:reason (:error r))))
    (is (str/includes? (:msg r) "999.0.0"))))

(deftest unknown-top-level-keys-warn
  (let [r (read-cfg {:vars []
                     :extra-key 1
                     :typo "x"})]
    (is (= 2 (count (:warnings r))))
    (is (some (fn [w] (str/includes? w ":extra-key")) (:warnings r)))
    (is (some (fn [w] (str/includes? w ":typo")) (:warnings r)))))

(deftest non-keyword-top-level-keys-warn-without-throwing
  ;; EDN allows string and numeric map keys; warning must not assume keywords.
  (let [r (read-cfg {:vars []
                     "stray" 1
                     42 "x"})]
    (is (= 2 (count (:warnings r))))
    (is (some (fn [w] (str/includes? w "\"stray\"")) (:warnings r)))
    (is (some (fn [w] (str/includes? w "42")) (:warnings r)))))

(deftest all-known-keys-produce-no-warnings
  (let [r (read-cfg {:description "D"
                     :root "tpl"
                     :min-frame-version "0.0.1"
                     :vars []
                     :computed {}
                     :raw []})]
    (is (= [] (:warnings r)))))

;; ---------------------------------------------------------------------------
;; Validation errors (all carry {:reason :config})
;; ---------------------------------------------------------------------------

(deftest missing-file-errors
  (let [dir (str (os/temp-dir) "/frame-config-missing-" (rand-int 100000000))]
    (mkdir dir)
    (let [r (try (config/read-config dir)
                 (catch e (ex-data e)))]
      (os/sh "rm" "-rf" dir)
      (is (= :config (:reason r))))))

(deftest invalid-edn-errors
  (let [r (read-edn "{:vars [")]
    (is (= :config (:reason (:error r))))))

(deftest non-map-errors
  (let [r (read-edn "[1 2 3]")]
    (is (= :config (:reason (:error r))))))

(deftest trailing-data-errors
  ;; A valid map followed by leftover text (e.g. a merge conflict) is rejected,
  ;; not silently ignored.
  (is (= :config (:reason (:error (read-edn "{:vars []} some junk here")))))
  (is (= :config (:reason (:error (read-edn "{:vars []}\n{:vars []}"))))))

(deftest var-without-key-errors
  (let [r (read-cfg {:vars [{:prompt "P"
                             :type :string}]})]
    (is (= :config (:reason (:error r))))))

(deftest var-without-prompt-errors
  (let [r (read-cfg {:vars [{:key :db
                             :type :string}]})]
    (is (= :config (:reason (:error r))))))

(deftest unknown-type-errors
  (let [r (read-cfg {:vars [{:key :db
                             :prompt "P"
                             :type :frobnicate}]})]
    (is (= :config (:reason (:error r))))))

(deftest enum-without-options-errors
  (let [r (read-cfg {:vars [{:key :db
                             :prompt "P"
                             :type :enum}]})]
    (is (= :config (:reason (:error r))))))

(deftest default-not-in-options-errors
  (let [r (read-cfg {:vars [{:key :db
                             :prompt "P"
                             :type :enum
                             :options ["sqlite" "postgres"]
                             :default "mysql"}]})]
    (is (= :config (:reason (:error r))))))

(deftest reserved-project-name-key-errors
  (let [r (read-cfg {:vars [{:key :project-name
                             :prompt "P"
                             :type :string}]})]
    (is (= :config (:reason (:error r))))))

(deftest reserved-now-keys-error
  (let [r (read-cfg {:vars [{:key :now-date
                             :prompt "P"
                             :type :string}]})]
    (is (= :config (:reason (:error r)))))
  (let [r (read-cfg {:vars [{:key :now-year
                             :prompt "P"
                             :type :string}]})]
    (is (= :config (:reason (:error r)))))
  ;; namespaced keys normalize to the same answer name and are also rejected
  (let [r (read-cfg {:vars [{:key :custom/now-date
                             :prompt "P"
                             :type :string}]})]
    (is (= :config (:reason (:error r))))))
